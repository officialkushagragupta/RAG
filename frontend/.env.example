# Copy this file to `.env` and adjust as needed. Never commit the real `.env`.

APP_TITLE="RAG Document Chatbot"
ENVIRONMENT=development

# Base URL of the backend FastAPI service (use the docker-compose service name
# "backend" instead of "localhost" when running via docker-compose).
BACKEND_API_URL=http://localhost:8000
API_V1_PREFIX=/api/v1
REQUEST_TIMEOUT_SECONDS=60

LOG_LEVEL=INFO

# Mirrors the backend's limits, for client-side validation feedback only --
# the backend is the source of truth and re-validates every upload.
MAX_UPLOAD_SIZE_MB=20
ALLOWED_FILE_EXTENSIONS=.pdf

# Mirrors backend/.env -- sidebar display labels only, the frontend never
# calls Gemini/embeddings directly.
GEMINI_MODEL_NAME=gemini-3.1-flash-lite
EMBEDDING_MODEL_NAME=models/gemini-embedding-001

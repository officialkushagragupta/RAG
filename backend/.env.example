# Copy this file to `.env` and fill in real values. Never commit the real `.env`.

# --- App ---------------------------------------------------------------------
APP_NAME="RAG Document Chatbot API"
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# --- Server --------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1

# --- CORS ------------------------------------------------------------------------
# Comma-separated origins, or "*" for all (development only).
CORS_ORIGINS=http://localhost:8501

# --- Logging -----------------------------------------------------------------------
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_NAME=app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# --- Gemini (required) ---------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_NAME=gemini-3.1-flash-lite

# --- Embeddings ------------------------------------------------------------------------
EMBEDDING_MODEL_NAME=models/gemini-embedding-001
# Truncated vector size (Matryoshka representation learning) -- the model's
# native size is 3072; Google's validated smaller sizes are 1536 and 768.
# Smaller = less ChromaDB storage/RAM, good for free-tier hosting.
EMBEDDING_DIMENSION=768

# --- ChromaDB ----------------------------------------------------------------------------
CHROMA_PERSIST_DIRECTORY=chroma_db
# Single fixed collection -- this app has exactly one active document at a time.
CHROMA_COLLECTION_NAME=document_rag

# --- Uploads -----------------------------------------------------------------------------
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20
ALLOWED_FILE_EXTENSIONS=.pdf
ALLOWED_MIME_TYPES=application/pdf

# --- Chunking ----------------------------------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Chat ------------------------------------------------------------------------------------
# Bounds the in-memory chat history for the active document (no DB/Redis persistence).
MAX_CHAT_HISTORY_TURNS=10
RECOMMENDED_QUESTIONS_COUNT=5
FOLLOWUP_QUESTIONS_COUNT=5

# --- Debug ---------------------------------------------------------------------------------
# When true, POST /chat responses include a `debug` block (retrieved chunk
# count + similarity scores) for tuning chunk size/overlap/retrieval
# quality. MUST be false in production.
ENABLE_DEBUG_METADATA=false
